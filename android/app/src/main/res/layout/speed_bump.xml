<?xml version="1.0" encoding="utf-8"?>
<!-- The intervention speed bump, drawn as a TYPE_APPLICATION_OVERLAY over the
     tracked app. Calm, never alarming: mascot, the stake, and two real choices.
     Headline + body are bound in code (OverlayController). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0D0B">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/sb_card"
        android:padding="24dp">

        <ImageView
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/cairn_mascot"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/sb_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="#ECEFE8"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sb_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:textColor="#AEB4A6"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/sb_stay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/sb_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="@string/sb_stay_strong"
            android:textColor="#16190F"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sb_open"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/sb_open_anyway"
            android:textColor="#AEB4A6"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
